#!/bin/sh
# pkg — Termux-compatible package manager for VSX (backed by Alpine apk)
# All Termux pkg commands work identically here.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

_info() { printf "${CYAN}[*]${NC} %s\n" "$*"; }
_ok()   { printf "${GREEN}[+]${NC} %s\n" "$*"; }
_warn() { printf "${YELLOW}[!]${NC} %s\n" "$*"; }
_err()  { printf "${RED}[x]${NC} %s\n" "$*" >&2; return 1; }

_check_apk() {
    command -v apk >/dev/null 2>&1 || { _err "apk not found. Are you inside the VSX terminal?"; return 1; }
}

_usage() {
    printf "${BOLD}pkg${NC} — Termux-compatible package manager (Alpine apk backend)\n\n"
    printf "Usage: pkg <command> [packages...]\n\n"
    printf "Commands:\n"
    printf "  update                   Fetch latest package index\n"
    printf "  upgrade                  Upgrade all installed packages\n"
    printf "  install  <pkg> [...]     Install packages\n"
    printf "  add      <pkg> [...]     Alias for install\n"
    printf "  remove   <pkg> [...]     Remove packages\n"
    printf "  uninstall <pkg> [...]    Alias for remove\n"
    printf "  reinstall <pkg> [...]    Remove then reinstall packages\n"
    printf "  search   [query]         Search available packages\n"
    printf "  show     <pkg>           Show package details\n"
    printf "  info     <pkg>           Alias for show\n"
    printf "  list-installed           List installed packages\n"
    printf "  list-all                 List all available packages\n"
    printf "  files    <pkg>           List files in an installed package\n"
    printf "  clean                    Clear package cache\n"
    printf "  help                     Show this message\n\n"
    printf "Examples:\n"
    printf "  pkg install git python3 nodejs\n"
    printf "  pkg search vim\n"
    printf "  pkg upgrade\n\n"
}

_check_apk || exit 1

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in

    update)
        _info "Updating package index..."
        apk update && _ok "Package index updated." || _err "Update failed."
        ;;

    upgrade)
        _info "Upgrading installed packages..."
        apk update && apk upgrade && _ok "All packages upgraded." || _err "Upgrade failed."
        ;;

    install|add)
        if [ $# -eq 0 ]; then
            _err "Usage: pkg install <package> [...]"
            exit 1
        fi
        _info "Installing: $*"
        apk update -q 2>/dev/null || true
        if apk add "$@"; then
            _ok "Installed: $*"
        else
            _err "Install failed for one or more packages."
            exit 1
        fi
        ;;

    remove|uninstall|del)
        if [ $# -eq 0 ]; then
            _err "Usage: pkg remove <package> [...]"
            exit 1
        fi
        _info "Removing: $*"
        if apk del "$@"; then
            _ok "Removed: $*"
        else
            _err "Remove failed."
            exit 1
        fi
        ;;

    reinstall)
        if [ $# -eq 0 ]; then
            _err "Usage: pkg reinstall <package> [...]"
            exit 1
        fi
        _info "Reinstalling: $*"
        apk del "$@" 2>/dev/null || true
        apk update -q 2>/dev/null || true
        if apk add "$@"; then
            _ok "Reinstalled: $*"
        else
            _err "Reinstall failed."
            exit 1
        fi
        ;;

    search)
        if [ $# -eq 0 ]; then
            apk search 2>/dev/null | sort
        else
            apk search "$@"
        fi
        ;;

    show|info)
        if [ $# -eq 0 ]; then
            _err "Usage: pkg show <package>"
            exit 1
        fi
        apk info -a "$@"
        ;;

    list-installed|list_installed)
        apk info 2>/dev/null | sort
        ;;

    list-all|list_all)
        apk update -q 2>/dev/null || true
        apk list -a 2>/dev/null | sort || apk search 2>/dev/null | sort
        ;;

    files)
        if [ $# -eq 0 ]; then
            _err "Usage: pkg files <package>"
            exit 1
        fi
        apk info -L "$@"
        ;;

    clean)
        _info "Cleaning package cache..."
        rm -rf /var/cache/apk/* 2>/dev/null || true
        _ok "Cache cleaned."
        ;;

    help|--help|-h)
        _usage
        ;;

    *)
        _warn "Unknown command: '$CMD'"
        printf "\n"
        _usage
        exit 1
        ;;
esac
