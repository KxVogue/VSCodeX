<?xml version="1.0" encoding="utf-8"?><!--
  ~ Circular background for the completion item icon badge.
  ~ The fill color is overridden at runtime via backgroundTintList
  ~ in CompletionListAdapter, so this just provides the circle shape.
  -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#FF6B8A9E" />
</shape>
